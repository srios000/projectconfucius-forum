
# Suppress baseline-browser-mapping and browserslist warnings about old data
BROWSERSLIST_IGNORE_OLD_DATA=true
BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true

# Forum's own Neon Postgres
DATABASE_URL=postgresql://user:pass@host/forum

# Shared auth Postgres (auth_sibling read role) — provided by projectconfucius-auth owner
AUTH_DATABASE_URL=postgresql://auth_sibling:pass@host/auth

# Better Auth (sibling)
BETTER_AUTH_URL=http://localhost:4000
BETTER_AUTH_SECRET=dev-secret-change-me
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:4000

# Cloudflare R2 — forum image bucket
FORUM_R2_ACCOUNT_ID=
FORUM_R2_ACCESS_KEY_ID=
FORUM_R2_SECRET_ACCESS_KEY=
FORUM_R2_BUCKET_NAME=project-confucius-forum
FORUM_R2_PUBLIC_URL=